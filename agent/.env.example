# ─────────────────────────────────────────────────────────────────────────────
# Prophet Agent — environment variables
#
# Only these 3 secrets need to be set. Everything else (RPC URLs, contract
# addresses, tuning params) is hardcoded in src/shared/config.ts and can be
# overridden here if needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Private keys (keep secret) ─────────────────────────────────────

# Oracle agent wallet — must match ORACLE_AGENT_ADDRESS used in deployment
PRIVATE_KEY_ORACLE=

# Market maker agent wallet — must match MARKET_MAKER_ADDRESS used in deployment
PRIVATE_KEY_MM=

# NaCl secret key for decrypting sealed bet commitments
# Paired with ORACLE_NACL_PUBLIC_KEY in the frontend .env.local
ORACLE_NACL_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL overrides — defaults are set in src/shared/config.ts
# Uncomment and change only if you need to override for a specific environment
# ─────────────────────────────────────────────────────────────────────────────

# OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
# OG_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai
# COMPUTE_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
# PROPHET_FACTORY_ADDRESS=0xCEd9B4405b9B7d09f6b7d44e6bA113EcF2627333
# POSITION_VAULT_ADDRESS=0x3f831E170f828DB2711403c6C3AD80e6fB02da75
# LIQUIDITY_POOL_ADDRESS=0x1A39bD969870e71d22A10b38F2845baBB56649A4
# REPRICE_INTERVAL_MS=300000
# ORACLE_MIN_CONFIDENCE=70
# ORACLE_CANCEL_ON_INCONCLUSIVE=0
# ORACLE_MAX_INCONCLUSIVE_ATTEMPTS=2
