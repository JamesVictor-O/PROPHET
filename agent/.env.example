# ── Wallets ──────────────────────────────────────────────────────────────────
# Oracle agent wallet — must match ORACLE_AGENT_ADDRESS in contracts/.env
PRIVATE_KEY_ORACLE=

# Market maker agent wallet — must match MARKET_MAKER_ADDRESS in contracts/.env
PRIVATE_KEY_MM=

# ── 0G Chain ─────────────────────────────────────────────────────────────────
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602

# ── 0G Storage ───────────────────────────────────────────────────────────────
# Get from: https://docs.0g.ai/developer-hub/building-on-0g/storage/sdk
OG_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai

# ── 0G Compute ───────────────────────────────────────────────────────────────
# Testnet provider running qwen-2.5-7b-instruct
# Find providers at: https://compute-marketplace.0g.ai/inference
COMPUTE_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836

# Contract addresses are auto-detected from chain ID — no manual config needed:
#   Testnet (16602): ledger 0xE708..., inference 0xa79F...
#   Mainnet (16661): ledger 0x2dE5..., inference 0x4734...

# Minimum 0G token balance before the agent auto-tops up the ledger account
# Agent will top up to COMPUTE_TOPUP_AMOUNT when balance drops below this
COMPUTE_MIN_BALANCE=10
COMPUTE_TOPUP_AMOUNT=50

# ── Deployed Contract Addresses ──────────────────────────────────────────────
# Copy these from contracts/.env after deployment
PROPHET_FACTORY_ADDRESS=
POSITION_VAULT_ADDRESS=
PAYOUT_DISTRIBUTOR_ADDRESS=
USDT_ADDRESS=

# ── Agent Tuning ─────────────────────────────────────────────────────────────
# How often the market maker reprices active markets (milliseconds)
REPRICE_INTERVAL_MS=60000

# Minimum confidence threshold for oracle to post a verdict (0-100)
# Below this, oracle marks market as INCONCLUSIVE
ORACLE_MIN_CONFIDENCE=70
